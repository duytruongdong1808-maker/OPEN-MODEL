AGENT_IMAP_HOST=
AGENT_IMAP_PORT=993
AGENT_IMAP_USER=
AGENT_IMAP_PASS=
AGENT_IMAP_MAILBOX=INBOX
AGENT_IMAP_USE_SSL=true
AGENT_ARCHIVE_MAILBOX=Archive

# Web mail agent v1 is read-only and only needs IMAP plus AGENT_OPS_TOKEN.
# SMTP settings are kept for the separate send-mail workflow.
AGENT_SMTP_HOST=
AGENT_SMTP_PORT=587
AGENT_SMTP_USER=
AGENT_SMTP_PASS=
AGENT_SMTP_STARTTLS=true
AGENT_SMTP_FROM=

AGENT_DRY_RUN=true
AGENT_ALLOWED_RECIPIENT_DOMAINS=[]
AGENT_DAILY_SEND_CAP=20
AGENT_REQUIRE_APPROVAL=true
AGENT_MAX_FETCH_BATCH=50
AGENT_OPS_TOKEN=
INTERNAL_HMAC_SECRET=change-me-to-at-least-32-bytes-long

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Recommended local value when using the Next.js proxy:
# http://localhost:3000/api/backend/auth/gmail/callback
GOOGLE_OAUTH_REDIRECT_URI=
# Legacy single-user token path. If this file exists, it is ignored and a startup warning is logged.
GOOGLE_OAUTH_TOKEN_PATH=outputs/app/gmail_token.json
GOOGLE_OAUTH_TOKEN_ENCRYPTION_KEY=

AUTH_SECRET=
AUTH_USERNAME=admin
AUTH_PASSWORD=
# Web Google sign-in callback:
# http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX_REQUESTS=120
# Set to share proxy rate limits across web instances; leave unset for in-memory local fallback.
REDIS_URL=redis://127.0.0.1:6379

OPEN_MODEL_API_BASE_URL=http://127.0.0.1:8000
OPEN_MODEL_LEDGER_DB_PATH=outputs/app/ledger.sqlite3
OPEN_MODEL_MAX_REQUEST_BYTES=262144
